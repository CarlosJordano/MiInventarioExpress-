<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MiInventarioExpress</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        #chat-messages { height: 300px; overflow-y: scroll; border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; background: #f8f9fa;}
    </style>
</head>
<body class="bg-light">
    {{{body}}}
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const chatForm = document.getElementById('chat-form');
        const chatInput = document.getElementById('chat-input');
        const chatMessages = document.getElementById('chat-messages');
        const currentUser = "{{username}}";

        if(chatForm) {
            chatForm.addEventListener('submit', (e) => {
                e.preventDefault();
                if (chatInput.value) {
                    socket.emit('chat message', { user: currentUser, text: chatInput.value });
                    chatInput.value = '';
                }
            });

            socket.on('chat message', (msg) => {
                const item = document.createElement('div');
                item.innerHTML = `<strong>${msg.user}:</strong> ${msg.text}`;
                chatMessages.appendChild(item);
                chatMessages.scrollTop = chatMessages.scrollHeight;
            });
        }
    </script>
</body>
</html>